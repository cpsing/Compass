{
  "name": "compass",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-tool product memory for AI-assisted development",
  "type": "module",
  "bin": {
    "compass-cli": "src/cli/index.ts",
    "compass-mcp": "src/mcp/server.ts"
  },
  "scripts": {
    "migrate": "tsx src/db/migrate.ts",
    "daemon": "tsx src/daemon/index.ts",
    "cli": "tsx src/cli/index.ts",
    "mcp": "tsx src/mcp/server.ts",
    "smoke": "tsx scripts/smoke-test.ts",
    "smoke:hook": "tsx scripts/smoke-test-hook.ts",
    "smoke:tree": "tsx scripts/smoke-test-tree.ts",
    "smoke:recon": "tsx scripts/smoke-test-reconciler.ts",
    "smoke:mcp": "tsx scripts/smoke-test-mcp.ts",
    "smoke:orphans": "tsx scripts/smoke-test-orphans.ts",
    "smoke:admin": "tsx scripts/smoke-test-admin.ts",
    "smoke:integration": "tsx scripts/smoke-test-integration.ts",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "dev:web": "next dev -p 18737",
    "build:web": "next build",
    "start:web": "next start -p 18737",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.5.0",
    "chokidar": "^4.0.1",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ulid": "^2.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.5.0",
    "playwright": "^1.61.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9"
  }
}
